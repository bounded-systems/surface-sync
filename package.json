{
  "name": "@bounded-systems/surface-sync",
  "version": "0.2.1",
  "description": "Type ontology for work-unit change-detection across GH/branch/worktree/tmux/beads",
  "bounded": {
    "tagline": "Type ontology for work-unit change-detection across GH/branch/worktree/tmux/beads",
    "kind": "room",
    "facet": "verb",
    "role": "transform",
    "domain": "surfaces"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/surface-sync.git"
  },
  "homepage": "https://github.com/bounded-systems/surface-sync#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/surface-sync/issues"
  },
  "keywords": [
    "surface-sync",
    "change-detection",
    "work-unit",
    "ontology",
    "disposition"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bounded-systems/disposition": "npm:@jsr/bounded-systems__disposition@^0.3.0"
  }
}
